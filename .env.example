# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qvault
# Connection pool — 10-20 人使用建議值如下
# pool_size = 常駐連線數，max_overflow = 尖峰時額外允許的連線數
# 總最大連線 = pool_size + max_overflow = 10 + 10 = 20
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300

# VLM Server (OpenAI-compatible API)
VLM_BASE_URL=http://vlm-server:8000/v1
VLM_API_KEY=dummy
VLM_MODEL=your-vlm-model-name
VLM_EMBEDDING_MODEL=your-embedding-model-name

# Processing
# 注意：VLM_MAX_CONCURRENCY 是 per-worker 的限制。
# 多 worker 模式下（uvicorn --workers N），實際併發 = N × VLM_MAX_CONCURRENCY。
# 單 worker（預設）對 async app 已經夠用，不建議開多 worker。
VLM_MAX_CONCURRENCY=5
VLM_RETRY_COUNT=2
VLM_TIMEOUT=120.0
SUBPROCESS_TIMEOUT=300.0

# VLM Sampling (Qwen3.5 Instruct defaults)
VLM_TEMPERATURE=0.7
VLM_TOP_P=0.8
VLM_TOP_K=20
VLM_MIN_P=0.0
VLM_PRESENCE_PENALTY=1.5
VLM_REPETITION_PENALTY=1.0

# Upload — use absolute path if code and data are on different mounts
# e.g., UPLOAD_DIR=/mnt/db/uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Logging — use absolute path for production
# e.g., LOG_DIR=/mnt/db/qvault/logs
LOG_DIR=./logs

# Auth (JWT verification — oauth2-proxy handles the OAuth flow)
# Use absolute path if code and keys are in different locations
AUTH_PUBLIC_KEY_PATH=./keys/public.pem
DEV_SKIP_AUTH=false
# Set ENVIRONMENT=production on prod servers (blocks DEV_SKIP_AUTH)
# ENVIRONMENT=production
